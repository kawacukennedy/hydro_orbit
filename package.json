{
  "name": "hydro-orbit",
  "version": "1.0.0",
  "private": true,
  "description": "Solar-powered, AI-driven smart irrigation for smallholder farmers",
  "keywords": [
    "smart-irrigation",
    "agritech",
    "iot",
    "esp32",
    "soil-sensors",
    "solar-powered",
    "react-native",
    "typescript",
    "turborepo"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "pnpm --filter=@hydro-orbit/web build && pnpm --filter=@hydro-orbit/api build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "start": "node apps/api/dist/index.js",
    "postinstall": "echo 'Hydro-Orbit dependencies installed. Run pnpm dev to start.'"
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "^3.0.0"
  },
  "packageManager": "pnpm@8.6.0"
}
